{
  "name": "test-app",
  "type": "module",
  "private": true,
  "dependencies": {
    "@pikku/core": "^0.11.0",
    "@pikku/jose": "^0.11.0",
    "@pikku/schema-cfworker": "^0.11.0",
    "eventsource": "^4.0.0",
    "ws": "^8.18.3",
    "@pikku/aws-services": "^0.11.0",
    "@pikku/lambda": "^0.11.0",
    "@pikku/pg": "^0.11.0",
    "postgres": "^3.4.5",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@pikku/cli": "^0.11.1",
    "@pikku/fetch": "^0.11.0",
    "@pikku/websocket": "^0.11.0",
    "@types/node": "^24",
    "@types/ws": "^8",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9",
    "@aws-sdk/client-apigatewaymanagementapi": "^3.914.0",
    "@aws-sdk/client-s3": "^3.914.0",
    "@aws-sdk/client-secrets-manager": "^3.914.0",
    "@aws-sdk/cloudfront-signer": "^3.914.0",
    "@aws-sdk/s3-request-presigner": "^3.914.0",
    "@types/aws-lambda": "^8.10.158",
    "esbuild": "^0.25.12",
    "serverless": "^4.21.1",
    "serverless-esbuild": "^1.55.1",
    "serverless-offline": "^14.4.0"
  },
  "scripts": {
    "build": "npm run build:offline --external:\"@aws-sdk/*\"",
    "ncu:pikku": "npx npm-check-updates -f '/@pikku/.*/'",
    "pikku": "pikku all",
    "test:http-fetch": "npx tsx client/http-fetch.ts",
    "test:http-sse": "npx tsx client/http-sse.ts",
    "test:rpc": "npx tsx client/rpc.ts",
    "test:websocket": "npx tsx client/websocket.ts",
    "test:queue": "npx tsx client/queue-worker.ts",
    "test:mcp": "npx tsx client/mcp.ts",
    "build:offline": "rm -rf dist && esbuild ./src/websocket.ts --format=esm --minify --bundle --keep-names --sourcemap --platform=node --target=node24 --outdir=dist --out-extension:.js=.mjs --metafile=meta.json --packages=external",
    "start": "npm run build:offline && serverless offline",
    "dev": "npm run build:offline && serverless offline",
    "test": "npm run test:websocket",
    "deploy": "npm run build && serverless deploy",
    "postinstall": "pikku all",
    "stackblitz": "concurrently 'pikku watch --silent' 'npm run dev'"
  },
  "main": "dist/index.mjs",
  "stackblitz": {
    "startCommand": "npm run stackblitz"
  }
}