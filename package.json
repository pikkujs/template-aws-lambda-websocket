{
  "name": "test-app",
  "type": "module",
  "private": true,
  "dependencies": {
    "@pikku/core": "^0.9.1",
    "@pikku/jose": "^0.9.2",
    "@pikku/schema-cfworker": "^0.9.1",
    "@pikku/aws-services": "^0.9.1",
    "@pikku/lambda": "^0.9.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@pikku/cli": "^0.9.1",
    "@pikku/fetch": "^0.9.1",
    "@pikku/websocket": "^0.9.1",
    "@types/node": "^22",
    "concurrently": "^9.2.0",
    "typescript": "^5.7",
    "@aws-sdk/client-apigatewaymanagementapi": "^3.714.0",
    "@aws-sdk/client-secrets-manager": "^3.714.0",
    "@types/aws-lambda": "^8.10.146",
    "esbuild": "^0.24.0",
    "serverless": "^4.10.1",
    "serverless-esbuild": "^1.54.6",
    "serverless-offline": "^14.4.0",
    "tsx": "^4.19.2"
  },
  "scripts": {
    "pikku": "pikku all",
    "test:template": "bash run-tests.sh --url http://localhost:3000/production --websocket",
    "test:http": "npx tsx clients/http.ts",
    "test:rpc": "npx tsx clients/rpc.ts",
    "test:websocket": "npx text clients/websocket.ts",
    "build:offline": "rm -rf dist && esbuild ./src/websocket.ts --format=esm --minify --bundle --keep-names --sourcemap --platform=node --target=node20 --outdir=dist --out-extension:.js=.mjs --metafile=meta.json",
    "dev": "npm run build:offline && serverless offline",
    "build": "npm run build:offline --external:\"@aws-sdk/*\"",
    "deploy": "npm run build && serverless deploy",
    "postinstall": "pikku all",
    "test": "npm run test:websocket",
    "stackblitz": "concurrently 'pikku --watch --silent' 'npm run dev'"
  },
  "main": "dist/index.mjs",
  "stackblitz": {
    "startCommand": "npm run stackblitz"
  }
}